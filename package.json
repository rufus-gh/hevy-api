{
  "name": "hevy-api",
  "version": "0.0.1",
  "description": "Unofficial client for the Hevy gym app API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "example": "npm run build && node examples/server.mjs",
    "example:smoke": "node examples/smoke-test.mjs",
    "mcp": "npm run build && node mcp/server.mjs",
    "mcp:test": "npm run build && node mcp/test-client.mjs"
  },
  "keywords": [
    "hevy",
    "gym",
    "fitness",
    "workout",
    "api"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
